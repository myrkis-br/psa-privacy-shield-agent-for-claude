# ============================================================
# PSA — Privacy Shield Agent
# Variáveis de ambiente para dados de teste
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# ATENÇÃO: O arquivo .env NUNCA deve ser commitado.
# Ele já está protegido pelo .gitignore.
# ============================================================

# Credenciais fictícias usadas pelos scripts geradores de teste
# (gerar_testes_gov.py, gerar_email_corporativo.py)
# Se não preenchidas, os scripts usam placeholders genéricos.

PSA_TEST_DB_PASS=
PSA_TEST_REDIS_PASS=
PSA_TEST_JWT_SECRET=
PSA_TEST_ADMIN_KEY=
PSA_TEST_DD_KEY=
PSA_TEST_SMTP_PASS=
PSA_TEST_WH_SECRET=
PSA_TEST_AWS_KEY=
PSA_TEST_AWS_SECRET=
PSA_TEST_API_TOKEN=
